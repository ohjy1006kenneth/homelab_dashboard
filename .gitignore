# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Local runtime data
/data/dashboard.db
/data/*.db-shm
/data/*.db-wal

# Migrated CasaOS compose files can contain passwords/tokens; keep them local.
/apps/*/docker-compose.yml
/apps/*/docker-compose.yaml
/apps/*/compose.yml
/apps/*/compose.yaml

# Migrated CasaOS application data can contain databases, passwords, tokens, and
# large runtime files. Keep it local and out of the public repo.
/appdata/

# App-local environment files copied from CasaOS can contain API keys.
/apps/*/.env
/apps/*/.env.*
